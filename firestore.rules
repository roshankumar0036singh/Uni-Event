rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to fetch user rate limit state
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // Enforce max 10 writes per user per minute (using request.time)
    function checkWriteRate(userId) {
      let userData = getUserData(userId);
      return userData.role == 'admin' ||
             !('lastWriteAt' in userData) ||
             (request.time.toMillis() - userData.lastWriteAt.toMillis() > 60000) ||
             userData.writeCountMinute <= 10;
    }

    // Enforce max 5 event creations per user per day
    function checkEventDailyRate(userId) {
      let userData = getUserData(userId);
      return userData.role == 'admin' ||
             !('lastEventDay' in userData) ||
             userData.lastEventDay != request.time.year() * 10000 + request.time.month() * 100 + request.time.day() ||
             userData.eventCountDay <= 5;
    }

    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId && !("role" in request.resource.data);
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.token.admin == true || 
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) && checkWriteRate(userId))
      );
    }
    match /clubs/{clubId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.token.admin == true;
      allow update, delete: if request.auth != null && request.auth.token.admin == true;
    }
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null && (
        request.auth.token.admin == true || 
        (request.auth.token.club == true && checkWriteRate(request.auth.uid) && checkEventDailyRate(request.auth.uid))
      );
      allow update, delete: if request.auth != null && (
        request.auth.token.admin == true || 
        (request.auth.uid == resource.data.ownerId && checkWriteRate(request.auth.uid))
      );

      match /participants/{participantId} {
        allow read: if request.auth != null && (
          request.auth.uid == participantId ||
          request.auth.token.admin == true ||
          request.auth.token.club == true ||
          request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)).data.ownerId
        );
        allow create: if request.auth != null &&
          request.auth.uid == participantId &&
          !request.resource.data.keys().hasAny([
            'isPaid', 'paymentStatus', 'paymentId', 'role', 'approved'
          ]);
        allow delete: if request.auth != null && request.auth.uid == participantId;
        allow update: if request.auth != null && request.auth.uid == participantId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'buddyPreference', 'updatedAt']);
      }

      match /checkIns/{checkInId} {
        allow read: if request.auth != null && (
          request.auth.token.admin == true ||
          request.auth.token.club == true ||
          request.auth.uid == resource.data.userId ||
          request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)).data.ownerId
        );
        allow create, update, delete: if request.auth != null &&
          exists(/databases/$(database)/documents/events/$(eventId)) && (
          request.auth.token.admin == true ||
          request.auth.token.club == true ||
          request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)).data.ownerId
        );
      }

      match /feedback/{feedbackId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == feedbackId;
      }

      match /messages/{messageId} {
        allow read: if request.auth != null && (
          exists(/databases/$(database)/documents/events/$(eventId)/participants/$(request.auth.uid)) ||
          request.auth.token.admin == true ||
          request.auth.token.club == true
        );
        allow create: if request.auth != null && (
          exists(/databases/$(database)/documents/events/$(eventId)/participants/$(request.auth.uid)) ||
          request.auth.token.admin == true ||
          request.auth.token.club == true
        ) && request.resource.data.userId == request.auth.uid;
      }
    }
    match /reminders/{rid} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId && checkWriteRate(request.auth.uid);
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /admin/{doc} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    match /feedback/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && checkWriteRate(request.auth.uid);

      allow read: if request.auth != null
                  && (resource.data.userId == request.auth.uid
                      || request.auth.token.admin == true);

      allow update, delete: if request.auth != null
                            && request.auth.token.admin == true;
    }
  }
}
