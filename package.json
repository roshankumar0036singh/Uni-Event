{
  "scripts": {
    "build": "tsc -p cloud-functions/tsconfig.json",
    "test:rules": "node --max-old-space-size=4096 ./node_modules/firebase-tools/lib/bin/firebase.js emulators:exec --only firestore \"jest tests/firestore.rules.test.ts --runInBand\"",
    "test:flows": "node --max-old-space-size=4096 ./node_modules/firebase-tools/lib/bin/firebase.js emulators:exec --only firestore \"jest tests/core-flows.test.ts --runInBand --coverage\"",
    "test:emulators": "node --max-old-space-size=4096 ./node_modules/firebase-tools/lib/bin/firebase.js emulators:exec --only firestore \"jest tests --runInBand --coverage\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "firebase-tools": "^15.18.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9"
  },
  "dependencies": {
    "expo-clipboard": "^56.0.3"
  }
}
