{
    "expo": {
        "name": "Centralized Event Platform",
        "slug": "centralized-event-platform",
        "owner": "vinaykt_06",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/UniEvent.png",
        "userInterfaceStyle": "light",
        "splash": {
            "image": "./assets/UniEvent.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "assetBundlePatterns": ["**/*"],
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.hack2skill.eventloop",
            "config": {
                "googleMapsApiKey": "YOUR_GOOGLE_MAPS_IOS_API_KEY"
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/UniEvent.png",
                "backgroundColor": "#ffffff"
            },
            "package": "com.hack2skill.eventloop",
            "config": {
                "googleMaps": {
                    "apiKey": "YOUR_GOOGLE_MAPS_ANDROID_API_KEY"
                }
            }
        },
        "web": {
            "favicon": "./assets/UniEvent.png",
            "bundler": "metro",
            "name": "UniEvent",
            "shortName": "UniEvent",
            "startUrl": "/",
            "display": "standalone",
            "backgroundColor": "#ffffff",
            "themeColor": "#ffffff",
            "description": "Centralized Event Platform for university clubs and events.",
            "orientation": "portrait",
            "dir": "ltr",
            "lang": "en-US"
        },
        "plugins": ["expo-notifications"],
        "scheme": "centralized-event-platform"
    }
}
