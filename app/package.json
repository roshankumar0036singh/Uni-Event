{
    "name": "centralized-event-platform",
    "version": "1.0.0",
    "main": "node_modules/expo/AppEntry.js",
    "scripts": {
        "patch-sea": "node scripts/patch-expo-sea.js",
        "prestart": "npm run patch-sea",
        "start": "expo start --port 19006",
        "android": "expo start --android",
        "ios": "expo start --ios",
        "web": "npm run patch-sea && expo start --web --port 19006",
        "build:web": "npm run patch-sea && expo export -p web --output-dir web-build",
        "lint": "eslint .",
        "format": "prettier --write .",
        "generate-sw": "node scripts/generate-sw.js",
        "test": "jest",
        "cypress:open": "cypress open",
        "cypress:run": "cypress run",
        "test:e2e": "start-server-and-test web http://localhost:19006 cypress:run"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/roshankumar0036singh/Uni-Event.git"
    },
    "keywords": [
        "event-management",
        "university",
        "react-native",
        "expo",
        "firebase",
        "qr-code",
        "attendance-tracking",
        "student-engagement"
    ],
    "author": "Roshan Kumar Singh",
    "license": "MIT",
